# AI Cold Outreach Personalizer - Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git (it's in .gitignore)

# Anthropic API Key (required)
# Get from: https://console.anthropic.com/
# Format: sk-ant-...
ANTHROPIC_API_KEY=

# Upstash Redis for Rate Limiting (optional for local dev, required for production)
# Get from: https://console.upstash.com/ -> Create Database -> REST API
# Format: https://...upstash.io
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
